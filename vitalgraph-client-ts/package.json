{
  "name": "@vital-ai/vitalgraph-client",
  "version": "0.1.3",
  "description": "TypeScript client for connecting to VitalGraph REST API servers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vital-ai/vital-graph.git",
    "directory": "vitalgraph-client-ts"
  },
  "author": {
    "name": "Marc Hadfield",
    "email": "marc@vital.ai"
  },
  "license": "Apache-2.0",
  "peerDependencies": {
    "@vital-ai/vital-model-utils": ">=0.1.7",
    "@vital-ai/vital-kg-model-ts": ">=0.1.0"
  },
  "devDependencies": {
    "@vital-ai/vital-model-utils": "^0.1.7",
    "@vital-ai/vital-kg-model-ts": "^0.1.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.7.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
