# Fuseki Configuration Environment Variables
# Copy this file to .env and modify as needed

# Fuseki Server Configuration
FUSEKI_PORT=3030
ADMIN_PASSWORD=admin123
JVM_ARGS=-Xmx2g

# Dataset Configuration
DATASET_NAME=vitalgraph
TDB_LOCATION=/fuseki/databases/vitalgraph

# VitalGraph Client Configuration
FUSEKI_SERVER_URL=http://localhost:3030
FUSEKI_USERNAME=admin
FUSEKI_PASSWORD=admin123
FUSEKI_TIMEOUT=30
