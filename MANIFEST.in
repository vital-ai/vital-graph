
# Include frontend build files
recursive-include vitalgraph/api/frontend/dist *

# Include README and license files
include README.md
include LICENSE

# Note: Config directories are excluded from PyPI distribution
# Users should create their own config files from templates in documentation

# Exclude development and test files
exclude .env
exclude .env.example
exclude .env.sparql-sql
exclude docker-compose.yml
exclude Dockerfile
exclude .dockerignore
exclude environment.yml
exclude pyrightconfig.json

# Exclude config directories
recursive-exclude vitalgraphdb_config *
recursive-exclude vitalhome *

# Exclude test directories
recursive-exclude test_scripts *
recursive-exclude test_data *
recursive-exclude test_files *
recursive-exclude test_files_download *

# Exclude development directories
recursive-exclude frontend *
recursive-exclude vitalgraph-client-ts *
recursive-exclude vitalgraph-jena-sidecar *
recursive-exclude vitalgraph_sparql_sql_dev *
recursive-exclude docs *
recursive-exclude planning *
recursive-exclude deploy *
recursive-exclude scripts *
recursive-exclude apps *
recursive-exclude archive *
recursive-exclude internal_data *
recursive-exclude generated_instances *
recursive-exclude domain_schema *
recursive-exclude jena *
recursive-exclude k8s *
recursive-exclude bin *
recursive-exclude registry *

# Exclude IDE and build artifacts
recursive-exclude .vscode *
recursive-exclude .idea *
recursive-exclude .vite *
recursive-exclude __pycache__ *
recursive-exclude .pytest_cache *
recursive-exclude dist *
recursive-exclude build *
recursive-exclude *.egg-info *
recursive-exclude .git *
recursive-exclude .github *

# Exclude specific file patterns
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude .DS_Store
global-exclude *.nq
global-exclude test_*.py
