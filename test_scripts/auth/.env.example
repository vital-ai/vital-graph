# Keycloak JWT Authentication Configuration
# Copy this to your project root .env file and fill in the values

# Keycloak Server Configuration
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id
KEYCLOAK_CLIENT_SECRET=your-client-secret-here-if-confidential
KEYCLOAK_USERNAME=your-username
KEYCLOAK_PASSWORD=your-password

# Production Fuseki Configuration
# Note: Include dataset path in URL if needed (e.g., https://fuseki.example.com/dataset)
FUSEKI_URL=https://fuseki.example.com

# Example values for local Keycloak testing:
# KEYCLOAK_URL=http://localhost:8080/auth
# KEYCLOAK_REALM=master
# KEYCLOAK_CLIENT_ID=admin-cli
# KEYCLOAK_USERNAME=admin
# KEYCLOAK_PASSWORD=admin

# Example values for production Fuseki:
# FUSEKI_URL=https://fuseki.example.com
