{
  "name": "flowbite-react-template-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:only": "tsc -b && vite build",
    "build": "npm run build:only && npm run deploy:local",
    "deploy:local": "mkdir -p ../vitalgraph/api/frontend && cp -r dist ../vitalgraph/api/frontend/",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "postinstall": "flowbite-react patch"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/leaflet": "^1.9.21",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vital-ai/vital-kg-model-ts": "^0.1.0",
    "@vital-ai/vital-model-utils": "^0.1.7",
    "@vital-ai/vitalgraph-client": "file:../vitalgraph-client-ts",
    "apexcharts": "^5.14.0",
    "cytoscape": "^3.34.0",
    "cytoscape-cola": "^2.5.1",
    "cytoscape-context-menus": "^4.2.1",
    "cytoscape-cose-bilkent": "^4.1.0",
    "cytoscape-dagre": "^4.0.0",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-fcose": "^2.2.0",
    "flowbite-react": "^0.11.7",
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/cytoscape": "^3.21.9",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.2.6"
  }
